# ═══════════════════════════════════════════════════════════════════════════════
#   منصة الدفع الإلكتروني — مؤسسة سر التميز والأناقة
#   انسخ هذا الملف إلى .env وعدّل القيم
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── التطبيق ──────────────────────────────────────────────────────────────────
DEBUG=False
HOST=0.0.0.0
PORT=5000
WORKERS=2

# ── الأمان ───────────────────────────────────────────────────────────────────
# أنشئ مفتاحاً عشوائياً قوياً: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── قاعدة البيانات ───────────────────────────────────────────────────────────
# SQLite (الافتراضي — مناسب للنشر الخفيف):
DATABASE_URL=sqlite:///./tamayoz.db

# PostgreSQL (للإنتاج الثقيل — فعّله وعطّل السطر أعلاه):
# DATABASE_URL=postgresql://tamayoz:changeme@db:5432/tamayoz_db

# ── PostgreSQL (مطلوب فقط عند استخدام docker-compose مع PostgreSQL) ──────────
# POSTGRES_DB=tamayoz_db
# POSTGRES_USER=tamayoz
# POSTGRES_PASSWORD=changeme

# ── بيانات المدير الافتراضي ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@tamayoz.com
ADMIN_PASSWORD=Admin@123456

# ── بوابة الدفع بيزاتي ───────────────────────────────────────────────────────
BEEZATI_API_KEY=your-beezati-api-key
BEEZATI_SECRET=your-beezati-secret
BEEZATI_BASE_URL=https://api.beezati.com/v1
BEEZATI_WEBHOOK_SECRET=your-webhook-secret
