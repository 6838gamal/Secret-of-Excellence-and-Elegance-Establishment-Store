# ── Application ────────────────────────────────
APP_NAME=متجر مؤسسة سر التميز والأناقة
DEBUG=False
HOST=0.0.0.0
PORT=5000

# ── Security ────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database ────────────────────────────────────
DATABASE_URL=sqlite:///./tamayoz.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/tamayoz_db

# ── Admin Credentials ───────────────────────────
ADMIN_EMAIL=admin@tamayoz.com
ADMIN_PASSWORD=Admin@123456

# ── Beezati Payment Gateway ─────────────────────
BEEZATI_API_KEY=your-beezati-api-key
BEEZATI_SECRET=your-beezati-secret
BEEZATI_BASE_URL=https://api.beezati.com/v1
BEEZATI_WEBHOOK_SECRET=your-webhook-secret
